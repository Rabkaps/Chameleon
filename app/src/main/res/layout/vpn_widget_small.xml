<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.ExpressiveBox">

    <!-- Thin Capsule Container (Locked to 48dp height and wrap_content width to form a floating One UI capsule pill widget) -->
    <LinearLayout
        android:id="@+id/widget_container"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:background="@drawable/widget_background_pill">

        <!-- Status Dot / Node Icon -->
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_node"
            android:tint="?attr/colorPrimary"
            android:layout_marginEnd="8dp" />

        <!-- Status Info Text -->
        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UNPROTECTED"
            android:textColor="?attr/colorOutline"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:layout_marginEnd="16dp" />

        <!-- Thin Capsule Toggle Button (Centered inside the 48dp height) -->
        <ImageView
            android:id="@+id/widget_button_toggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/widget_button_background"
            android:src="@drawable/ic_power"
            android:padding="7dp"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Toggle Connection" />

    </LinearLayout>

</FrameLayout>
