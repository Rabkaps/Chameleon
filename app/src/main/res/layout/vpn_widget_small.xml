<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.Chameleon">

    <!-- Invisible background view to absorb the launcher's automatic clipping & card styling -->
    <View
        android:id="@android:id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!-- True Capsule/Pill Container (Perfect capsule ends with 1000dp corner radius, untouched by launcher clipping) -->
    <LinearLayout
        android:id="@+id/widget_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_background_pill"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp">

        <!-- Circular Action Toggle Button on the Left (styled exactly like Samsung's Optimise widget) -->
        <FrameLayout
            android:id="@+id/widget_button_toggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_button_background"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Toggle Connection">

            <ImageView
                android:id="@+id/widget_button_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_power"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <!-- Status and Node Text Column on the Right -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/widget_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UNPROTECTED"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_node_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to secure"
                android:textColor="@color/widget_text_secondary"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
