<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.Chameleon">

    <!-- Dummy background view to intercept the launcher's automatic squircle clipping -->
    <FrameLayout
        android:id="@android:id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!-- True Capsule/Pill Container (Matching Samsung native widget bounds) -->
    <LinearLayout
        android:id="@+id/widget_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_background_pill"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <!-- Circular Action Toggle Button on the Left -->
        <FrameLayout
            android:id="@+id/widget_button_toggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_button_background"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Toggle Connection">

            <ImageView
                android:id="@+id/widget_button_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_power"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <!-- Status text only (Clean, spacious, un-cramped One UI 8.5 Style) -->
        <TextView
            android:id="@+id/widget_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Not Protected"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</FrameLayout>
